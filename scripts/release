#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CHANGELOG="$REPO_ROOT/CHANGELOG.md"

usage() {
  echo "Usage: $(basename "$0") vX.Y.Z"
  exit 1
}

[ "${1:-}" = "" ] && usage
VERSION="$1"
[[ "$VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || { echo "Error: version must be vX.Y.Z"; exit 1; }

cd "$REPO_ROOT"

# Ensure working tree is clean (CHANGELOG aside)
DIRTY=$(git status --porcelain | grep -v 'CHANGELOG' || true)
[ -n "$DIRTY" ] && { echo "Error: uncommitted changes present"; git status --short; exit 1; }

# Ensure [Unreleased] has content to promote
grep -q '^\#\# \[Unreleased\]' "$CHANGELOG" || { echo "Error: no [Unreleased] section found in CHANGELOG.md"; exit 1; }
UNRELEASED_CONTENT=$(awk '/^## \[Unreleased\]/{found=1; next} found && /^## \[/{exit} found{print}' "$CHANGELOG")
[ -z "$(echo "$UNRELEASED_CONTENT" | tr -d '[:space:]')" ] && { echo "Error: [Unreleased] section is empty — add changelog entries first"; exit 1; }

TODAY="$(date +%Y-%m-%d)"
BARE="${VERSION#v}"

echo "Releasing $VERSION ($TODAY)..."

# 1. Promote [Unreleased] → [VERSION] in CHANGELOG
sd '## \[Unreleased\]' "## [Unreleased]\n\n## [$BARE] - $TODAY" "$CHANGELOG"

# Update comparison links
PREV_TAG=$(git tag --sort=-version:refname | grep '^v' | head -1)
PREV_BARE="${PREV_TAG#v}"
sd "\[Unreleased\]: https://github\.com/danhorst/md-tools/compare/.*\.\.\.HEAD" \
   "[Unreleased]: https://github.com/danhorst/md-tools/compare/${VERSION}...HEAD\n[$BARE]: https://github.com/danhorst/md-tools/compare/${PREV_BARE}...${BARE}" \
   "$CHANGELOG"

# 2. Commit and tag
git add CHANGELOG.md
git commit -m "Release $VERSION"
git tag -a "$VERSION" -m "$VERSION"

# 3. Push — CI handles release creation and formula update
git push origin main
git push origin "$VERSION"

echo "Tag pushed. GitHub Actions will create the release and update the tap formula."
